{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "opener:default",
    "fs:scope-home",
    "fs:allow-mkdir",
    "fs:allow-home-read-recursive",
    "fs:allow-write-text-file",
    "fs:allow-read-text-file",
    "fs:write-all",
    "dialog:allow-open",
    "dialog:allow-save",
    "dialog:allow-message",
    "store:default"
  ]
}